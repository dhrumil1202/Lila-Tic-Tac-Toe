# Local development defaults
NAKAMA_SERVER_KEY=defaultkey
NAKAMA_CORS_ALLOW_ORIGIN=http://localhost:5173
NAKAMA_SESSION_ENCRYPTION_KEY=defaultencryptionkey
NAKAMA_REFRESH_ENCRYPTION_KEY=defaultrefreshencryptionkey

# For production, replace with strong secrets and your frontend URL.
# Example:
# NAKAMA_SERVER_KEY=change-me
# NAKAMA_CORS_ALLOW_ORIGIN=https://your-app.vercel.app
# NAKAMA_SESSION_ENCRYPTION_KEY=32+_bytes_long_random_secret_1
# NAKAMA_REFRESH_ENCRYPTION_KEY=32+_bytes_long_random_secret_2
